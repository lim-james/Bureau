# Bureau voice config — copy to ~/.bureau/voice.env and fill in.
#   mkdir -p ~/.bureau && cp voice/voice.env.example ~/.bureau/voice.env
#   chmod 600 ~/.bureau/voice.env      # it holds a secret
#
# The real file lives at ~/.bureau/voice.env (outside the repo) and is never
# committed. This template is safe to commit — it has no secrets.

# Required for the natural voice. Get a key at https://elevenlabs.io (Profile ->
# API Keys), scoped to Text-to-Speech. Without it, narration falls back to the
# robotic Windows SAPI voice.
ELEVENLABS_API_KEY=

# Optional. Default narration verbosity when you don't type a level after
# "jarvis": quiet | normal | verbose | briefing. Defaults to quiet if unset.
#   quiet    — essentials only (started, done, blocked)
#   normal   — + phase transitions
#   verbose  — + curated mechanical sub-steps
#   briefing — "voice of the model": speaks the decisions themselves, in full,
#              so you can listen instead of reading (skips verbose mechanics)
BUREAU_VOICE_LEVEL=quiet

# Optional. Voice to use (any voice_id from your ElevenLabs account).
# Default is Jessica (playful, bright, warm). Uncomment to override.
# BUREAU_VOICE_ID=cgSgspJ2msm6clMCkdW9

# Optional. Low-latency model. Uncomment to override.
# BUREAU_VOICE_MODEL=eleven_turbo_v2_5

# Optional — ONLY needed on a network that intercepts TLS (e.g. some corporate
# networks), where requests fail with "unable to get local issuer certificate".
# Capture the presented chain once with:
#   openssl s_client -showcerts -connect api.elevenlabs.io:443 </dev/null 2>/dev/null \
#     | awk '/BEGIN CERTIFICATE/,/END CERTIFICATE/' > ~/.bureau/corp-chain.pem
# On a normal network you do NOT need this.
# BUREAU_VOICE_CA=~/.bureau/corp-chain.pem
